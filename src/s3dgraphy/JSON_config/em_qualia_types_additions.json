              "getty_aat": "300055649",
              "cidoc_crm": "E54_Dimension"
            },
            "data_type": "float",
            "units": ["cm2", "m2"],
            "suffixes": ["_min", "_max", "_approx", "_preserved", "_reconstructed"],
            "expected_extractors": ["direct_measurement", "3d_model_measurement", "drawing_measurement", "calculated"]
          },
          {
            "id": "volume",
            "name": "Volume",
            "description": "Volumetric measurement of the unit",
            "mappings": {
              "getty_aat": "300055652",
              "cidoc_crm": "E54_Dimension"
            },
            "data_type": "float",
            "units": ["cm3", "m3", "liters"],
            "suffixes": ["_min", "_max", "_approx", "_preserved", "_reconstructed"],
            "expected_extractors": ["3d_model_measurement", "calculated", "water_displacement"]
          },
          {
            "id": "perimeter",
            "name": "Perimeter",
            "description": "Perimeter measurement of the unit in plan",
            "mappings": {
              "getty_aat": "300055644",
              "cidoc_crm": "E54_Dimension"
            },
            "data_type": "float",
            "units": ["cm", "m"],
            "suffixes": ["_min", "_max", "_approx", "_preserved"],
            "expected_extractors": ["direct_measurement", "3d_model_measurement", "drawing_measurement"]
          }
        ],
        "modification_notes": [
          "All existing dimensional qualia (height, width, length, thickness, depth, diameter) should support suffixes: _min, _max, _approx, _preserved, _reconstructed",
          "Example: height_min, height_max, height_preserved"
        ]
      },
