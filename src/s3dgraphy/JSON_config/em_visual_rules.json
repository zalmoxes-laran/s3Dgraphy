    "document_roles": {
        "_comment": "Axis 1 of the three-axis Master-Document classification (EM 1.6). Declares how this document participates in the reconstructive reasoning. 'analytical' = primary source for direct reasoning about this context. 'comparative' = external comparison material (other sites, epochs, typologies). Not visualized as colour — metadata only.",
        "analytical": {
            "description": "Primary source for direct reconstructive reasoning about this context."
        },
        "comparative": {
            "description": "External document used as comparative reference (other sites, other epochs, typologies)."
        }
    },
    "document_content_natures": {
        "_comment": "Axis 2 of the three-axis Master-Document classification (EM 1.6). Describes the intrinsic nature of the document's content. '2d_object' = image, drawing, photograph, text. '3d_object' = three-dimensional model. Not visualized as colour — metadata only.",
        "2d_object": {
            "description": "Image, drawing, photograph, or textual document."
        },
        "3d_object": {
            "description": "Three-dimensional model (mesh, laser scan, photogrammetric reconstruction)."
        }
    },
    "document_variant_styles": {
        "_comment": "Axis 3 of the three-axis Master-Document classification (EM 1.6). Declares how the document's Representation Model (RM) is spatialized in the 3D scene. The 'geometry' property drives both the GraphML DocumentNode border colour (in yEd) and the RM contour colour in the 3D viewport (per the v1.6 toggle). Documents without an RM (e.g. PDF articles, bibliographies) omit the geometry property entirely — no node, no colour. Colours follow the EM certainty scale (red / orange / yellow) reinterpreted as geometric-quality grading. Kept in sync with the reference nodes in templates/em_palette_template.graphml (n37 red, n39 orange, n38 yellow).",
        "default": {
            "border_color": "#000000",
            "border_style": "solid",
            "border_width": 1.0
        },
        "reality_based": {
            "border_color": "#9B3333",
            "border_style": "solid",
            "border_width": 4.0,
            "description": "Robust sensor / algorithmic positioning: photogrammetric model, photo from a calibrated photogrammetric sequence, instrumentally-surveyed special find."
        },
        "observable": {
            "border_color": "#D86400",
            "border_style": "solid",
            "border_width": 4.0,
            "description": "Position reconstructed with approximation from rigorous archaeological documentation (plans, sections, measured drawings). Criterion-based, residual uncertainty remains."
        },
        "asserted": {
            "border_color": "#D8BD30",
            "border_style": "solid",
            "border_width": 4.0,
            "description": "Compositional positioning asserted by the operator, without claim of restitution (e.g. placing a comparative element in the scene for analytical purposes)."
        },
        "em_based": {
            "border_color": "#4A7FB8",
            "border_style": "solid",
            "border_width": 4.0,
            "description": "3D reconstruction produced via the Extended Matrix methodology — the document itself IS an EM-derived reconstruction. Typical case: a hypothesis model built from another EM graph, used here as a comparative or derivative source."
        }
    },
