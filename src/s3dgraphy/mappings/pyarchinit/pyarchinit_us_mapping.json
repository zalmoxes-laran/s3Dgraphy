{
    "name": "pyArchInit US Table",
    "description": "Mapping for pyArchInit Stratigraphic Units table (us_table)",
    "version": "1.6.0",
    "table_settings": {
        "format_type": "sqlite",
        "table_name": "us_table",
        "node_name_template": "{area}.{unita_tipo}.{us}"
    },
    "column_mappings": {
        "sito": {
            "is_filter": true,
            "filter_required": true,
            "display_name": "Site",
            "description": "Archaeological site name. Marked as a required filter so consumer applications can restrict the import to a single site (pyArchInit databases typically store many sites in one us_table)."
        },
        "area": {
            "is_filter": true,
            "filter_required": false,
            "display_name": "Excavation Area",
            "description": "Excavation area / sector. Optional secondary filter, combined with 'sito' via AND."
        },
        "unita_tipo": {
            "is_filter": true,
            "filter_required": false,
            "display_name": "Stratigraphic Unit Type",
            "description": "Type of stratigraphic unit (US, USM, etc.). Optional filter combined with sito/area via AND."
        },
        "us": {
            "node_type": "US",
            "is_id": true
        },
        "d_stratigrafica": {
            "node_type": "US",
            "is_description": true,
            "target_id_column": "US"
        },
        "d_interpretativa": {
            "node_type": "PropertyNode",
            "property_name": "Interpretation",
            "display_name": "Interpretation",
            "description": "Interpretation of the stratigraphic unit",
            "create_empty": true
        },
        "attivita": {
            "node_type": "PropertyNode",
            "property_name": "Activity",
            "display_name": "Activity type",
            "description": "Type of archaeological activity",
            "create_empty": true
        },
        "struttura": {
            "node_type": "PropertyNode",
            "property_name": "Structure",
            "display_name": "Structure type",
            "description": "Type of archaeological structure",
            "create_empty": true
        }
    },
    "relations": [
        {
            "source_column": "us",
            "target_column": "d_interpretativa",
            "edge_type": "has_property"
        },
        {
            "source_column": "us",
            "target_column": "attivita",
            "edge_type": "has_property"
        },
        {
            "source_column": "us",
            "target_column": "struttura",
            "edge_type": "has_property"
        }
    ]
}
